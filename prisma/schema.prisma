datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 业务表部分
// 图片表
// type 1->普通图片；2->livephoto
model Images {
  id                   String                 @id @default(cuid()) @db.VarChar(50)
  image_name           String?                @db.Text
  url                  String?                @db.Text
  preview_url          String?                @db.Text
  video_url            String?                @db.Text
  original_key         String?                @db.Text
  preview_key          String?                @db.Text
  video_key            String?                @db.Text
  blurhash             String?                @db.Text
  exif                 Json?                  @db.Json
  shoot_at             DateTime?              @db.Timestamp
  labels               Json?                  @db.Json
  width                Int                    @default(0)
  height               Int                    @default(0)
  lon                  String?
  lat                  String?
  title                String?                @db.VarChar(200)
  detail               String?                @db.Text
  type                 Int                    @default(1) @db.SmallInt
  show                 Int                    @default(1) @db.SmallInt
  show_on_mainpage     Int                    @default(1) @db.SmallInt
  featured             Int                    @default(0) @db.SmallInt
  sort                 Int                    @default(0) @db.SmallInt
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamp
  updatedAt            DateTime?              @updatedAt @map("updated_at") @db.Timestamp
  del                  Int                    @default(0) @db.SmallInt
  imagesAlbumsRelation ImagesAlbumsRelation[]
  imagesTagsRelation   ImagesTagsRelation[]

  // 性能优化：添加高频查询字段索引
  @@index([del, show]) // 联合索引：用于筛选未删除且公开的图片
  @@index([featured]) // 精选图片查询索引
  @@index([createdAt]) // 时间排序索引
  @@index([show, show_on_mainpage]) // 首页展示筛选索引
  @@index([del, show, featured]) // 多条件筛选联合索引
  // 注意：JSONB 字段的 GIN 索引需要在迁移文件中手动创建，Prisma schema 不支持
  @@map("images")
}

// 配置表
model Configs {
  id           String    @id @default(cuid()) @db.VarChar(50)
  config_key   String    @unique @db.VarChar(200)
  config_value String?   @db.Text
  detail       String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamp

  @@map("configs")
}

// 相册表
model Albums {
  id                   String                 @id @default(cuid()) @db.VarChar(50)
  name                 String                 @db.VarChar(200)
  album_value          String                 @unique @db.Text
  detail               String?                @db.Text
  theme                String                 @default("0") @db.Text
  show                 Int                    @default(1) @db.SmallInt
  sort                 Int                    @default(0) @db.SmallInt
  random_show          Int                    @default(1) @db.SmallInt
  license              String?                @db.Text
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamp
  updatedAt            DateTime?              @updatedAt @map("updated_at") @db.Timestamp
  del                  Int                    @default(0) @db.SmallInt
  imagesAlbumsRelation ImagesAlbumsRelation[]
  image_sorting        Int                    @default(1) @db.SmallInt
  cover                String?                @db.Text
  guide_albums_relation GuideAlbumsRelation[]

  // 性能优化：添加高频查询字段索引
  @@index([del, show]) // 相册筛选联合索引
  @@index([album_value]) // 相册值查询索引（已有 unique，但显式声明提升可读性）
  @@map("albums")
}

// 图片相册关联表
model ImagesAlbumsRelation {
  albums      Albums @relation(fields: [album_value], references: [album_value])
  album_value String @db.Text
  images      Images @relation(fields: [imageId], references: [id])
  imageId     String @db.VarChar(50)
  sort        Int    @default(0) @db.SmallInt

  @@id([imageId, album_value])
  // 性能优化：添加关联查询索引
  @@index([imageId]) // 图片关联查询索引
  @@index([album_value]) // 相册关联查询索引
  @@index([imageId, album_value]) // 联合查询索引
  @@index([album_value, sort]) // 相册内图片排序查询优化索引
  @@map("images_albums_relation")
}

// better-auth
model User {
  id               String      @id
  name             String      @unique @db.VarChar(50)
  email            String      @db.VarChar(200)
  emailVerified    Boolean
  image            String?
  twoFactorEnabled Boolean?
  createdAt        DateTime    @db.Timestamp()
  updatedAt        DateTime    @db.Timestamp()
  sessions         Session[]
  accounts         Account[]
  TwoFactor        TwoFactor[]
  passkeys         Passkey[]

  @@unique([email])
  @@map("user")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor")
}

model Session {
  id        String   @id
  expiresAt DateTime @db.Timestamp()
  token     String
  createdAt DateTime @db.Timestamp()
  updatedAt DateTime @db.Timestamp()
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamp()
  refreshTokenExpiresAt DateTime? @db.Timestamp()
  scope                 String?
  password              String?   @db.VarChar(200)
  createdAt             DateTime  @db.Timestamp()
  updatedAt             DateTime  @db.Timestamp()

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @db.Timestamp()
  createdAt  DateTime? @db.Timestamp()
  updatedAt  DateTime? @db.Timestamp()

  @@map("verification")
}

// Passkey 表 (符合 better-auth passkey 插件要求)
model Passkey {
  id           String   @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String   @unique
  counter      Int      @default(0)
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime @db.Timestamp()
  aaguid       String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkey")
}

// 新增标签表
model Tags {
  id        String                @id @default(cuid()) @db.VarChar(50)
  name      String                @unique @db.VarChar(200)
  category  String?               @db.VarChar(200)
  parentId  String?               @db.VarChar(50)
  parent    Tags?                 @relation("TagChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  Tags[]                @relation("TagChildren")
  detail    String?               @db.Text
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime?            @updatedAt @map("updated_at") @db.Timestamp
  images    ImagesTagsRelation[]

  @@map("tags")
}

// 图片与标签多对多关系
model ImagesTagsRelation {
  id        String @id @default(cuid()) @db.VarChar(50)
  imageId   String @db.VarChar(50)
  tagId     String @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  image Images @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tag   Tags   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("images_tags_relation")
  @@unique([imageId, tagId])
  // 性能优化：添加关联查询索引
  @@index([imageId]) // 图片标签关联查询索引
  @@index([tagId]) // 标签图片关联查询索引
}

// 访问日志表：用于后台访问统计
model VisitLog {
  id        String   @id @default(cuid()) @db.VarChar(50)
  path      String   @db.Text
  pageType  String   @db.VarChar(50)   // home / gallery / album / admin / other
  ip        String?  @db.VarChar(100)
  userAgent String?  @db.Text
  referrer  String?  @db.Text
  source    String?  @db.VarChar(50)   // direct / referer / search
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([createdAt])
  @@index([path])
  @@map("visit_log")
}

// 攻略表
model Guides {
  id           String              @id @default(cuid()) @db.VarChar(50)
  title        String              @db.VarChar(200)
  country      String              @db.VarChar(100)
  city         String              @db.VarChar(100)
  days         Int                 @db.SmallInt
  start_date   DateTime?           @db.Timestamp
  end_date     DateTime?           @db.Timestamp
  cover_image  String?             @db.Text
  content      Json?               @db.Json
  show         Int                 @default(1) @db.SmallInt
  sort         Int                 @default(0) @db.SmallInt
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime?           @updatedAt @map("updated_at") @db.Timestamp
  del          Int                 @default(0) @db.SmallInt
  components   GuideComponents[]
  albums       GuideAlbumsRelation[]
  modules      GuideModules[]
  tableOfContents GuideTableOfContents[]

  @@index([del, show])
  @@index([country, city])
  @@index([days])
  @@map("guides")
}

// 攻略组件表
model GuideComponents {
  id         String    @id @default(cuid()) @db.VarChar(50)
  guide_id   String    @db.VarChar(50)
  type       String    @db.VarChar(50)   // image, map, table, list, text
  content    Json?     @db.Json
  sort       Int       @default(0) @db.SmallInt
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamp

  guide      Guides    @relation(fields: [guide_id], references: [id], onDelete: Cascade)

  @@index([guide_id])
  @@map("guide_components")
}

// 攻略相册关联表
model GuideAlbumsRelation {
  id         String    @id @default(cuid()) @db.VarChar(50)
  guide_id   String    @db.VarChar(50)
  album_id   String    @db.VarChar(50)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp

  guide      Guides    @relation(fields: [guide_id], references: [id], onDelete: Cascade)
  album      Albums    @relation(fields: [album_id], references: [id], onDelete: Cascade)

  @@index([guide_id])
  @@index([album_id])
  @@unique([guide_id, album_id])
  @@map("guide_albums_relation")
}

// 攻略模块表（新版块化编辑器）
model GuideModules {
  id          String    @id @default(cuid()) @db.VarChar(50)
  guide_id    String    @db.VarChar(50)
  name        String    @db.VarChar(100)
  template    String?   @db.VarChar(50)  // 模板类型：itinerary, expense, checklist, attraction, food, tips
  sort        Int       @default(0) @db.SmallInt
  is_hidden   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamp

  guide       Guides              @relation(fields: [guide_id], references: [id], onDelete: Cascade)
  contents    GuideModuleContents[]

  @@index([guide_id])
  @@index([guide_id, sort])
  @@map("guide_modules")
}

// 模块内容表（支持多类型内容）
model GuideModuleContents {
  id          String    @id @default(cuid()) @db.VarChar(50)
  module_id   String    @db.VarChar(50)
  type        String    @db.VarChar(50)   // text, image, table, video, code, latex, link, card
  content     Json?     @db.Json          // 存储具体内容
  sort        Int       @default(0) @db.SmallInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamp

  module      GuideModules @relation(fields: [module_id], references: [id], onDelete: Cascade)

  @@index([module_id])
  @@index([module_id, sort])
  @@map("guide_module_contents")
}

// 攻略目录表
model GuideTableOfContents {
  id          String    @id @default(cuid()) @db.VarChar(50)
  guide_id    String    @db.VarChar(50)
  title       String    @db.VarChar(200)
  level       Int       @default(1) @db.SmallInt       // 1: 一级目录, 2: 二级目录
  target_id   String?   @db.VarChar(50)               // 关联的模块ID或内容ID
  target_type String?   @db.VarChar(50)               // module 或 content
  sort        Int       @default(0) @db.SmallInt
  is_hidden   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp

  guide       Guides    @relation(fields: [guide_id], references: [id], onDelete: Cascade)

  @@index([guide_id])
  @@index([guide_id, sort])
  @@map("guide_table_of_contents")
}