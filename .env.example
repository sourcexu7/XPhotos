DATABASE_URL="postgresql://user:password@localhost:5432/xphotos?schema=public&connection_limit=25&pool_timeout=20&connect_timeout=10"
DIRECT_URL="postgresql://user:password@localhost:5432/xphotos?schema=public"

POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=xphotos

# JWT secret for admin authentication (used in middleware.ts)
JWT_SECRET=your-jwt-secret-min-32-chars

# better-auth secret (generate with: npx auth secret)
AUTH_SECRET=your-auth-secret
AUTH_TRUST_HOST=true


# Redis 缓存（可选，未配置时自动禁用，不影响业务）
# 格式：redis://[:password@]host:port/db
REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_PASSWORD=your-redis-password
# 显式禁用 Redis（即使配置了 URL 也禁用）
# REDIS_DISABLED=true

# Node environment
NODE_ENV=production