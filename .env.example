# ============================================================
# XPhotos 环境变量模板
# 使用方法：复制本文件为 .env，填入你自己的值
# ============================================================

# ---------- 数据库（必须） ----------
# PostgreSQL 连接串。connection_limit / pool_timeout / connect_timeout 为性能调优参数
DATABASE_URL="postgresql://postgres:your_password@127.0.0.1:5432/xphotos?schema=public&connection_limit=25&pool_timeout=20&connect_timeout=10"

# Prisma 迁移专用直连地址（通常与上面相同，但不设连接池参数）
DIRECT_URL="postgresql://postgres:your_password@127.0.0.1:5432/xphotos?schema=public"

# ---------- 认证（必须） ----------
# JWT 签名密钥，至少 32 字符。用于管理员登录 Token 签名与校验
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-change-me-at-least-32-characters

# ---------- 运行环境 ----------
# development / production
NODE_ENV=development

# ---------- Redis 缓存（可选，未配置时自动禁用） ----------
# 格式：redis://[:password@]host:port/db
REDIS_URL=redis://127.0.0.1:6379/0

# 单独的 Redis 密码（可选。密码也可直接写在 REDIS_URL 里）
# REDIS_PASSWORD=your-redis-password

# 显式禁用 Redis（即使配置了 URL 也禁用）
# REDIS_DISABLED=true
